<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <title>TakeIt - Buy Ticket</title>
        <link rel="stylesheet" type="text/css" href="/main-style.css" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Playwrite+DK+Uloopet:wght@100..400&display=swap" rel="stylesheet">
    </head>
    <body>
        
        <div class="nav-bar playwrite-dk-uloopet" style="display: flex; justify-content: space-between; align-items: center;">
			<div class="dropdown">
				<span>Login in</span>
				<div class="dropdown-menu">
					<a href="/customer">Login in</a>
					<a href="/customer/register">Register</a>
				</div>
			</div>
			<div style="padding:10px;">
				<a href="?lang=en">English</a> |
				<a href="?lang=zh">中文</a>
			</div>
		</div>

        <div class="nav-bar playwrite-dk-uloopet">
            <ul>
                <li><a href="/"><%= __("home") %></a></li>
			    <li><a href="/concert"><%= __("concert") %></a></li>
                <li><a href="#Orderhistory"><%= __("order_history") %></a></li>
                <li><a href="#profile"><%= __("profile") %></a></li>
            </ul>
        </div>

        <div class="concert playfair-display">
    <div class="row g-4">
        <% orders.forEach(order => { %>
            <div class="col-12 border-bottom pb-4 mb-4">
                <h3 class="fw-bold"><%= order.title %></h3>
                
                <p class="text-muted">
                    <i class="bi bi-geo-alt"></i> <%= order.location %> | 
                    <i class="bi bi-calendar-event"></i> <%= order.date %> <%= order.time %>
                </p>

                <div class="mb-2">
                    <% order.tickets.forEach(ticket => { %>
                        <span class="badge bg-secondary me-2">
                            Zone <%= ticket.zone %>: <%= ticket.quantity %> ticket(s)
                        </span>
                    <% }) %>
                </div>

                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-secondary">Order time: <%= order.buying_time %></small>
                    <div class="fs-5">
                        Total Price: <span class="fw-bold text-primary">$<%= order.total_paid %></span>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>
    </body>
</html>