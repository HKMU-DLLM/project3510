<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <title><%= __('takeit_buy_ticket') %></title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" type="text/css" href="/main-style.css" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Playwrite+DK+Uloopet:wght@100..400&display=swap" rel="stylesheet">
    </head>
    <body>

		<div class="nav-bar playwrite-dk-uloopet">
			<div class="dropdown">
				<% if (!isLoggedIn) { %>
					<span><a href="/customer"><%= __('login') %></a></span>
				<% } else if (currentUser && currentUser.role === 'customer') { %>
					<span><%= __('welcome') %> <%= currentUser.name ? currentUser.name : 'Customer' %></span>
					<div class="dropdown-menu">
						<a href="/customer/orderhistory"><%= __('order_history') %></a>
						<a href="/customer"><%= __('account') %></a>
						<a href="/customer/logout"><%= __('logout') %></a>
					</div>
				<% } %>
			</div>

			<div class="lang-links">
				<a href="?lang=en">Eng</a> |
				<a href="?lang=zh">中</a>
			</div>
		</div>
        
<ul class="main-links">
            <li><a href="/"><%= __("home") %></a></li>
			<li><a href="/concert"><%= __("concert") %></a></li>
			<li><a href="/customer/orderhistory"><%= __("order_history") %></a></li>
			<li><a href="/customer/user_profile"><%= __("profile") %></a></li>
		</ul>

        <div class="buy-ticket-container playfair-display">
            <p>
                <%= ticket.title %>
                <%= ticket.date %>
                <%= ticket.location %>
            </p>    
            <form id="purchaseForm" action="/customer/order" method="POST">
               <input type="hidden" name="concert_id" value="<%= ticket.id %>">

                <div class="mb-3">
                    <label><%= __('zone_a') %> ($<%= ticket.ZoneA_Price %>)</label>
                    <input type="number" name="qty_A" id="qty_A" value="0" min="0" class="form-control">
                    <input type="hidden" name="price_A" value="<%= ticket.ZoneA_Price %>">
                </div>

                <div class="mb-3">
                    <label><%= __('zone_b') %> ($<%= ticket.ZoneB_Price %>)</label>
                    <input type="number" name="qty_B" id="qty_B" value="0" min="0" class="form-control">
                    <input type="hidden" name="price_B" value="<%= ticket.ZoneB_Price %>">
                </div>

                <button type="submit" class="btn btn-success"><%= __('confirm_purchase') %></button> 
                        
            </form>
        </div>
    </body>

    <script>
        document.getElementById('purchaseForm').onsubmit = function(e) {
            const qtyA = parseInt(document.getElementById('qty_A').value) || 0;
            const qtyB = parseInt(document.getElementById('qty_B').value) || 0;

            if (qtyA + qtyB <= 0) {
                e.preventDefault();
                alert("Please select at least one ticket before purchasing.");
            }
        };
    </script>
</html>