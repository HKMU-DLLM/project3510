<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof concert !== 'undefined' ? 'Edit Concert' : 'Add New Concert' %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="/main-style.css" />
</head>
<body style="background-color: #F5FBE6;">
<div class="nav-bar playwrite-dk-uloopet">
    <div class="dropdown">
        <% if (currentUser && currentUser.role === 'admin') { %>
            <span><%= __('welcome') %> Admin</span>
            <div class="dropdown-menu">
                <a href="/admin/profile"><%= __('concert_management') %></a>
                <a href="/admin/logout"><%= __('logout') %></a>
            </div>
        <% } %>
    </div>
    <div class="lang-links">
        <a href="?lang=en">Eng</a> |
        <a href="?lang=zh">中</a>
    </div>
</div>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header <%= typeof concert !== 'undefined' ? 'bg-warning' : 'bg-primary' %> text-white">
                    <h4 class="mb-0"><%= typeof concert !== 'undefined' ? 'Edit' : __('create_new') %><%= __('concert_event') %></h4>
                </div>
                <div class="card-body">
                    <% 
                    
                        let actionUrl = "/admin/concerts/create"; 
                        if (typeof concert !== 'undefined') {
                            actionUrl = "/admin/edit/" + concert.id; 
                        }
                    %>
                    <form action="<%= actionUrl %>" method="POST">
                        
                        <div class="row mb-4">
                            <div class="col-md-8">
                                <label for="title" class="form-label fw-bold"><%= __('concert_title') %></label>
                                <input type="text" class="form-control" id="title" name="title" 
                                    placeholder="e.g. Summer Rock Night"
                                    value="<%= typeof concert !== 'undefined' ? concert.title : '' %>" required>
                            </div>
                            <div class="col-md-4">
                                <label for="organizer" class="form-label fw-bold"><%= __('organizer') %></label>
                                <input type="text" class="form-control" id="organizer" name="organizer" 
                                    placeholder="e.g. Live Nation"
                                    value="<%= typeof concert !== 'undefined' ? concert.organizer : '' %>" required>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="ZoneA_Ticket" class="form-label fw-bold"><%= __('zone_a_capacity') %></label>
                                <input type="number" class="form-control" id="ZoneA_Ticket" name="ZoneA_Ticket" 
                                    value="<%= typeof concert !== 'undefined' ? concert.ZoneA_Ticket : '150' %>" min="0">
                            </div>
                            <div class="col-md-6">
                                <label for="ZoneA_Price" class="form-label fw-bold"><%= __('zone_a_price') %></label>
                                <input type="number" step="0.01" class="form-control" id="ZoneA_Price" name="ZoneA_Price" 
                                    value="<%= typeof concert !== 'undefined' ? concert.ZoneA_Price : '' %>" required>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label for="ZoneB_Ticket" class="form-label fw-bold"><%= __('zone_b_capacity') %></label>
                                <input type="number" class="form-control" id="ZoneB_Ticket" name="ZoneB_Ticket" 
                                    value="<%= typeof concert !== 'undefined' ? concert.ZoneB_Ticket : '150' %>" min="0">
                            </div>
                            <div class="col-md-6">
                                <label for="ZoneB_Price" class="form-label fw-bold"><%= __('zone_b_price') %></label>
                                <input type="number" step="0.01" class="form-control" id="ZoneB_Price" name="ZoneB_Price" 
                                    value="<%= typeof concert !== 'undefined' ? concert.ZoneB_Price : '' %>" required>
                            </div>
                        </div>

                        <hr>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="location" class="form-label fw-bold"><%= __('location') %></label>
                                <input type="text" class="form-control" id="location" name="location" 
                                    value="<%= typeof concert !== 'undefined' ? concert.location : '' %>" required>
                            </div>

                            <div class="col-md-3 mb-4">
                                <label for="date" class="form-label fw-bold"><%= __('event_date') %></label>
                                <input type="date" class="form-control" id="date" name="date" 
                                    value="<%= typeof concert !== 'undefined' ? concert.date : '' %>" required>
                            </div>

                            <div class="col-md-3 mb-4">
                                <label for="time" class="form-label fw-bold"><%= __('start_time') %></label>
                                <input type="time" class="form-control" id="time" name="time" 
                                    value="<%= typeof concert !== 'undefined' ? concert.time : '' %>" required>
                            </div>
                        </div>

                        <div class="mb-4 form-check ms-1">                            
                            <input type="checkbox" class="form-check-input" id="is_published" name="is_published" value="1" 
                                <%= (typeof concert !== 'undefined' && concert.ready_to_launch == 1) || typeof concert === 'undefined' ? 'checked' : '' %>>
                            
                            <label class="form-check-label fw-bold" for="is_published">
                                <%= __('launch_immediately') %>
                            </label>
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <a href="/admin/profile" class="btn btn-outline-secondary"><%= __('cancel') %></a>
                            <button type="submit" class="btn btn-success px-4">
                                <%= typeof concert !== 'undefined' ? __('update_concert') : __('save_concert') %>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>