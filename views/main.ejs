<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<title>TakeIt</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
		<link rel="stylesheet" type="text/css" href="/main-style.css" />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Playwrite+DK+Uloopet:wght@100..400&display=swap" rel="stylesheet">
	</head>
    <body>

		<div class="nav-bar playwrite-dk-uloopet">
			<div class="dropdown">
				<% if (!isLoggedIn) { %>
					<span><a href="/customer">Login</a></span>
				<% } else if (currentUser && currentUser.role === 'customer') { %>
					<span>Welcome! <%= currentUser.name ? currentUser.name : 'Customer' %></span>
					<div class="dropdown-menu">
						<a href="/customer/orderhistory">Order History</a>
						<a href="/customer">Account</a>
						<a href="/customer/logout">Logout</a>
					</div>
				<% } %>
			</div>

			<div class="lang-links" style="padding:10px;">
				<a href="?lang=en">Eng</a> |
				<a href="?lang=zh">中</a>
			</div>
		</div>
		<ul class="main-links">
            <li><a href="/"><%= __("home") %></a></li>
			<li><a href="/concert"><%= __("concert") %></a></li>
			<li><a href="/customer/orderhistory"><%= __("order_history") %></a></li>
			<li><a href="#profile"><%= __("profile") %></a></li>
		</ul>
		
		<div class="banner-container">
			<div class="banner-controls">
				<button id="scrollPrev" class="banner-scroll-btn banner-scroll-prev">❮</button>
				<button id="scrollNext" class="banner-scroll-btn banner-scroll-next">❯</button>
			</div>
			<div class="banner-track" id="bannerTrack">
					<div class="banner">
						<div class="details-poster">
						<img src="/Laufey.jpg" width="550px">
						</div>
						<div class="details-info playfair-display">
							<div class="details-title">Laufey: A Matter of Time Tour in Hong Kong</div>
							<div class="details-date">Tuesday, 12 May 2026</div>
							<div class="details-location">AsiaWorld-Arena</div>
							<div><a href="/customer/buy_ticket" class="ticket-btn"><%= __("ticket") %></a></div>
						</div>
					</div>

					<div class="banner">
						<div class="details-poster">
						<img src="/tuki.jpg" width="550px">
						</div>
						<div class="details-info playfair-display">
							<div class="details-title">tuki. 1st ASIA TOUR 2026 in HONG KONG</div>
							<div class="details-date">Saturday&Sunday, 9-10 May 2026</div>
							<div class="details-location">AsiaWorld-Runway 11</div>
							<div><a href="/customer/buy_ticket" class="ticket-btn"><%= __("ticket") %></a></div>
						</div>
					</div>			
					
					<div class="banner">
						<div class="details-poster">
						<img src="/King Gnu.jpg" width="550px">
						</div>
						<div class="details-info playfair-display">
							<div class="details-title">King Gnu CEN+RAL Tour 2026 - Hong Kong</div>
							<div class="details-date">Friday&Saturday, 29-30 May 2026</div>
							<div class="details-location">AsiaWorld-Arena</div>
							<div><a href="/customer/buy_ticket" class="ticket-btn"><%= __("ticket") %></a></div>
						</div>
					</div>

					<div class="banner">
						<div class="details-poster">
						<img src="/MC x CONSTANCE x Gareth.T" width="550px">
						</div>
						<div class="details-info playfair-display">
							<div class="details-title">《b.balance presents Music is Live &#124; &#60;3 symbol of love &#124; MC x CONSTANCE x Gareth.T 》</div>
							<div class="details-date playfair-display">Sunday, 16 May 2026</div>
							<div class="details-location">AsiaWorld-Arena</div>
							<div><a href="/customer/buy_ticket" class="ticket-btn"><%= __("ticket") %></a></div>
						</div>
					</div>
				</div>
			</div>

			<div class="w-75 mx-auto mt-5">
				<div class="list-group list-group-flush">
					<% concert.forEach(c => { %>
						
					<a href="#" class="list-group-item list-group-item-action">
						<div class="d-flex w-100 justify-content-between">
							<h5 class="mb-1"><%= c.title %></h5>
							<small><%= c.date %></small>
						</div>
						<p class="mb-1 text-muted">| <%= c.location %></p>
					</a>
						<% }) %>					
    </body>

	<script>
		let listItems = document.querySelectorAll('.list-group-item');
		let removeActiveClasses = () => {
			listItems.forEach(item => {
				item.classList.remove('active');
			});
		};

		listItems.forEach(item => {
			item.addEventListener('click', () => {
				removeActiveClasses();
				item.classList.add('active');
			});
		});

		// Banner scroll functionality
		const bannerTrack = document.getElementById('bannerTrack');
		const scrollPrevBtn = document.getElementById('scrollPrev');
		const scrollNextBtn = document.getElementById('scrollNext');
		let currentScroll = 0;
		let autoScrollInterval;

		const updateBannerPosition = () => {
			bannerTrack.style.transform = `translateX(${currentScroll}%)`;
		};

		const goToNextSlide = () => {
			currentScroll -= 25;
			if (currentScroll < -75) {
				currentScroll = 0;
			}
			updateBannerPosition();
		};

		const goToPrevSlide = () => {
			currentScroll += 25;
			if (currentScroll > 0) {
				currentScroll = -75;
			}
			updateBannerPosition();
		};

		scrollNextBtn.addEventListener('click', () => {
			goToNextSlide();
			resetAutoScroll();
		});

		scrollPrevBtn.addEventListener('click', () => {
			goToPrevSlide();
			resetAutoScroll();
		});

		const startAutoScroll = () => {
			autoScrollInterval = setInterval(goToNextSlide, 5000);
		};

		const resetAutoScroll = () => {
			clearInterval(autoScrollInterval);
			startAutoScroll();
		};

		startAutoScroll();
	</script>
</html>