<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= __('takeit') %><%= __("profile") %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" type="text/css" href="/main-style.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Playwrite+DK+Uloopet:wght@100..400&display=swap" rel="stylesheet">
    <style>
        /* Maintaining consistency with your provided background and fonts */
        body { 
            background-color: #F5FBE6; 
            font-family: "Playfair Display", serif;
        }
        .profile-container {
            max-width: 600px;
            margin: 50px auto;
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        }
        .avatar-circle {
            width: 80px;
            height: 80px;
            background: #2c3e50;
            color: #BADA55;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            font-size: 2rem;
            margin: 0 auto 20px;
        }
        .info-label {
            font-size: 0.8rem;
            text-transform: uppercase;
            color: #95a5a6;
            letter-spacing: 1px;
            font-weight: 700;
        }
        .info-value {
            font-size: 1.2rem;
            color: #2c3e50;
            margin-bottom: 20px;
            border-bottom: 1px solid #f8f9fa;
            padding-bottom: 5px;
        }
    </style>
</head>
<body>

    <div class="nav-bar playwrite-dk-uloopet">
        <div class="dropdown">
            <% if (!isLoggedIn) { %>
                <span><a href="/customer"><%= __('login') %></a></span>
            <% } else if (currentUser && currentUser.role === 'customer') { %>
                <span><%= __('welcome') %> <%= currentUser.name ? currentUser.name : 'Customer' %></span>
                <div class="dropdown-menu">
                    <a href="/customer/orderhistory"><%= __('order_history') %></a>
                    <a href="/customer"><%= __('account') %></a>
                    <a href="/customer/logout"><%= __('logout') %></a>
                </div>
            <% } %>
        </div>
        <div class="lang-links">
            <a href="?lang=en">Eng</a> |
            <a href="?lang=zh">中</a>
        </div>
    </div>

    <ul class="main-links">
        <li><a href="/"><%= __("home") %></a></li>
        <li><a href="/concert"><%= __("concert") %></a></li>
		<li><a href="/customer/crderhistory"><%= __("order_history") %></a></li>
        <li><a href="/customer/user_profile" class="active"><%= __("profile") %></a></li>
    </ul>

    <div class="container">
        <div class="profile-container">
            <div class="text-center">
                <div class="avatar-circle playwrite-dk-uloopet">
                    <%= user.name.charAt(0).toUpperCase() %>
                </div>
                <h2 class="fw-bold mb-4"><%= __("profile") %></h2>
            </div>

            <div class="row px-md-4">
                <div class="col-12">
                    <div class="info-label"><%= __('name') %></div>
                    <div class="info-value"><%= user.name %></div>
                </div>

                <div class="col-12">
                    <div class="info-label"><%= __('email_address') %></div>
                    <div class="info-value"><%= user.email %></div>
                </div>

                <div class="col-12 mt-4">
                    <a href="/customer/orderhistory" class="btn btn-outline-dark w-100 rounded-pill">
                        <%= __('view_my_orders') %>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>