<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <title>TakeIt - Buy Ticket</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" type="text/css" href="/main-style.css" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Playwrite+DK+Uloopet:wght@100..400&display=swap" rel="stylesheet">
    </head>
    <body>
        
		<div class="nav-bar playwrite-dk-uloopet">
			<div class="dropdown">
				<% if (!isLoggedIn) { %>
					<span><a href="/customer"><%= __('login') %></a></span>
				<% } else if (currentUser && currentUser.role === 'customer') { %>
					<span><%= __('welcome') %> <%= currentUser.name ? currentUser.name : 'Customer' %></span>
					<div class="dropdown-menu">
						<a href="/customer/orderhistory"><%= __('order_history') %></a>
						<a href="/customer"><%= __('account') %></a>
						<a href="/customer/logout"><%= __('logout') %></a>
					</div>
				<% } %>
			</div>
			<div class="lang-links">
				<a href="?lang=en">Eng</a> |
				<a href="?lang=zh">中</a>
			</div>
		</div>

<ul class="main-links">
            <li><a href="/"><%= __("home") %></a></li>
			<li><a href="/concert"><%= __("concert") %></a></li>
			<li><a href="/customer/orderhistory"><%= __("order_history") %></a></li>
			    <li><a href="/customer/user_profile"><%= __("profile") %></a></li>
		</ul>

        <div class="concert playfair-display">
    <div class="mt-3" style="padding-left: 200px; padding-right: 200px;"> 
        <% orders.forEach(order => { %>
            <div class="col-12 border-bottom pb-4 mb-4">
                <h3 class="fw-bold"><%= order.title %></h3>
                
                <p class="text-muted">
                    <i class="bi bi-geo-alt"></i> <%= order.location %> | 
                    <i class="bi bi-calendar-event"></i> <%= order.date %> <%= order.time %>
                </p>

                <div class="mb-2">
                    <% order.tickets.forEach(ticket => { %>
                        <span class="badge bg-secondary me-2">
                            <%= __('zone') %> <%= ticket.zone %>: <%= ticket.quantity %> <%= __('ticket_s') %>
                        </span>
                    <% }) %>
                </div>

                <div class="d-flex justify-content-between align-items-center">
                    <small class="text-secondary"><%= __('order_time') %><%= order.buying_time %></small>
                    <div class="fs-5">
                        <%= __('total_price') %><span class="fw-bold text-primary">$<%= order.total_paid %></span>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
</div>
    </body>
</html>