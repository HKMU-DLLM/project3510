<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <title>TakeIt - Buy Ticket</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" type="text/css" href="/main-style.css" />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Playwrite+DK+Uloopet:wght@100..400&display=swap" rel="stylesheet">
    </head>
    <body>
        
		<div class="nav-bar playwrite-dk-uloopet">
			<div class="dropdown">
				<% if (!isLoggedIn) { %>
					<span><a href="/customer">Login</a></span>
				<% } else if (currentUser && currentUser.role === 'customer') { %>
					<span>Welcome! <%= currentUser.name ? currentUser.name : 'Customer' %></span>
					<div class="dropdown-menu">
						<a href="/customer/orderhistory">Order History</a>
						<a href="/customer">Account</a>
						<a href="/customer/logout">Logout</a>
					</div>
				<% } %>
			</div>
			<div class="lang-links">
				<a href="?lang=en">Eng</a> |
				<a href="?lang=zh">中</a>
			</div>
		</div>

        <ul class="main-links">
            <li><a href="/"><%= __("home") %></a></li>
			<li><a href="/concert"><%= __("concert") %></a></li>
			<li><a href="/customer/orderhistory"><%= __("order_history") %></a></li>
			<li><a href="#profile"><%= __("profile") %></a></li>
		</ul>

        <div class="concert playfair-display">
            <div class="row g-4">
				<% concert.forEach(c => { %>
				<div class="col-md-4">
					<div class="card h-100" id="concert-card">
						<div class="card-body">
							<h4 class="card-title"><%= c.title %></h4>
							<p class="card-text text-muted">
                                <%= c.date %><%= c.location %>
                            </p>
							<% if (c.ready_to_launch !== 0) { %>
                                <a href="/customer/buy_ticket/<%= c.id %>" class="btn btn-primary w-100" id="view-button">
                                    Take It
                                </a>
                            <% } else { %>
                                <button class="btn btn-secondary w-100" disabled>Not yet launched</button>
                            <% } %>
						</div>
					</div>
				</div>
				<% }) %>
			</div>
        </div>
    </body>
</html>