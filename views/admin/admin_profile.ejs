<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard | Manage Concerts</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        body { background-color: #f8f9fa; }
        .table-container { background: white; border-radius: 10px; padding: 20px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .status-badge { width: 80px; }
    </style>
</head>
<body>
<div class="nav-bar playwrite-dk-uloopet">
    <div class="lang-links">
        <a href="?lang=en">Eng</a> |
        <a href="?lang=zh">中</a>
    </div>
</div>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h3"><%= __('concert_management') %></h2>
        <a href="/admin/form" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> <%= __('create_new_activity') %>
        </a>
    </div>

    <div class="table-container">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th><%= __('event_details') %></th>
                        <th><%= __('organizer') %></th>
                        <th><%= __('location') %></th>
                        <th><%= __('date_time') %></th>
                        <th class="text-center"><%= __('status') %></th>
                        <th class="text-center"><%= __('actions') %></th>
                    </tr>
                </thead>
                <tbody>
                    <% concerts.forEach(concert => { %>
                        <tr>
                            <td>
                                <div class="fw-bold text-dark"><%= concert.title %></div>
                            </td>
                            <td><%= concert.organizer %></td>
                            <td><i class="bi bi-geo-alt"></i> <%= concert.location %></td>
                            <td>
                                <div class="small"><%= concert.date %></div>
                                <div class="small text-muted"><%= concert.time %></div>
                            </td>
                            <td class="text-center">
                                <% if (concert.ready_to_launch == 1) { %>
                                    <span class="badge bg-success status-badge"><%= __('published') %></span>
                                <% } else { %>
                                    <span class="badge bg-secondary status-badge"><%= __('draft') %></span>
                                <% } %>
                            </td>
                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <% if (concert.ready_to_launch !== 0) { %>
                                        <a href="/admin/sales_report/<%= concert.id %>" class="btn btn-sm btn-outline-info" title="View Sales">
                                            <i class="bi bi-graph-up"></i>
                                        </a>
                                    <% } %>
                                    <a href="/admin/edit/<%= concert.id %>" class="btn btn-sm btn-outline-warning" title="Edit Concert">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>