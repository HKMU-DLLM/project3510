<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <table>
    <thead>
        <tr>
            <th>Title</th>
            <th>Organizer</th>
            <th>Location</th>
            <th>Date</th>
            <th>Time</th>
            <th>Published</th>
        </tr>
        </thead>
        
        <tbody>
            <% concerts.forEach(concert => { %>
                <tr>
                    <td><%= concert.title %></td>
                    <td><%= concert.organizer %></td>
                    <td><%= concert.location %></td>
                    <td><%= concert.date %></td>
                    <td><%= concert.time %></td>
                    <td><%= concert.ready_to_launch == 1 ? 'Yes' : 'No' %></td>
                    <td><a href="/admin/sales_report/<%= concert.id %>">Summary</a></td>
                    <td><a href="/admin/edit/<%= concert.id %>">Edit</a></td>
                </tr>
            <% }); %>
        </tbody>
    </table>
    <a href="/admin/form">Create New Activity</a>
</body>
</html>