<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TakeIt - Order Successful</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" type="text/css" href="/main-style.css" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Playwrite+DK+Uloopet:wght@100..400&display=swap" rel="stylesheet">
    
    <style>
        body { background-color: #F5FBE6; font-family: "Playfair Display", serif; }
        
        .confirmation-card {
            max-width: 700px;
            margin: 50px auto;
            background: white;
            border-radius: 25px;
            overflow: hidden;
            box-shadow: 0 15px 40px rgba(0,0,0,0.06);
        }

        .success-banner {
            background-color: #BADA55;
            color: #2c3e50;
            padding: 30px;
            text-align: center;
        }

        .order-details {
            padding: 40px;
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
            border-bottom: 1px dashed #eee;
        }

        .total-row {
            margin-top: 20px;
            padding: 20px;
            background-color: #f8f9fa;
            border-radius: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .playwrite { font-family: "Playwrite DK Uloopet", cursive; }
    </style>
</head>
<body>

    <div class="nav-bar playwrite-dk-uloopet">
        <div class="dropdown">
            <% if (!isLoggedIn) { %>
                <span><a href="/customer"><%= __('login') %></a></span>
            <% } else if (currentUser && currentUser.role === 'customer') { %>
                <span><%= __('welcome') %> <%= currentUser.name ? currentUser.name : 'Customer' %></span>
                <div class="dropdown-menu">
                    <a href="/customer/orderhistory"><%= __('order_history') %></a>
                    <a href="/customer/user_profile"><%= __('account') %></a>
                    <a href="/customer/logout"><%= __('logout') %></a>
                </div>
            <% } %>
        </div>
        <div class="lang-links">
            <a href="?lang=en">Eng</a> | <a href="?lang=zh">中</a>
        </div>
    </div>

    <ul class="main-links playwrite-dk-uloopet">
        <li><a href="/"><%= __("home") %></a></li>
        <li><a href="/concert"><%= __("concert") %></a></li>
        <li><a href="/customer/orderhistory"><%= __("order_history") %></a></li>
        <li><a href="/customer/user_profile"><%= __("profile") %></a></li>
    </ul>

    <div class="container">
        <div class="confirmation-card">
            <div class="success-banner">
                <i class="bi bi-check-circle-fill fs-1"></i>
                <h2 class="fw-bold mt-2"><%= __('order_confirmed') %></h2>
                <p class="mb-0"><%= __('thank_you_purchase') %><%= currentUser.name %>.</p>
            </div>

            <div class="order-details">
                <h5 class="fw-bold mb-4 text-uppercase text-muted small" style="letter-spacing: 2px;"><%= __('event_details') %></h5>
                
                <div class="mb-4">
                    <h3 class="fw-bold mb-1"><%= order.title %></h3>
                    <p class="text-muted">
                        <i class="bi bi-geo-alt me-2"></i><%= order.location %> <br>
                        <i class="bi bi-calendar3 me-2"></i><%= order.date %> | <%= order.time %>
                    </p>
                </div>

                <h5 class="fw-bold mb-3 text-uppercase text-muted small" style="letter-spacing: 2px;"><%= __('your_tickets') %></h5>
                
                <div class="detail-row">
                    <span class="text-muted"><%= __('zone_quantity') %></span>
                    <span class="fw-bold"><%= __('zone') %><%= order.chosen_zone %> (x<%= order.quantity %>)</span>
                </div>

                <div class="detail-row">
                    <span class="text-muted"><%= __('order_id') %></span>
                    <span class="fw-bold text-uppercase">#<%= order.order_id %></span>
                </div>

                <div class="detail-row">
                    <span class="text-muted"><%= __('booking_time') %></span>
                    <span><%= order.buying_time %></span>
                </div>

                <div class="total-row">
                    <span class="fw-bold fs-5"><%= __('total_paid') %></span>
                    <span class="fw-bold fs-3 text-dark">
                        $<%= (order.total_paid) ? order.total_paid.toLocaleString() : '0.00' %>
                    </span>                
                </div>

                <div class="mt-5 d-flex gap-3">
                    <a href="/customer/orderhistory" class="btn btn-dark w-100 py-3 rounded-pill fw-bold">
                        <i class="bi bi-ticket-perforated me-2"></i> <%= __('view_tickets') %>
                    </a>
                    <button onclick="window.print()" class="btn btn-outline-dark px-4 rounded-pill">
                        <i class="bi bi-printer"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>